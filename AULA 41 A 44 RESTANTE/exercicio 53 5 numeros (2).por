programa {
  funcao inicio() {
   inteiro i, soma=0,x=5
   
   para (i=0; x>=1 e x <=5; x--){
    
    escreva("Digite um numero: ")
    leia (i)
    soma = soma + i
    escreva("Digite um numero: ")
    leia (i)
    soma = soma + i
    escreva("Digite um numero: ")
    leia (i)
    soma = soma + i
    escreva("Digite um numero: ")
    leia (i)
    soma = soma + i
    escreva("Digite um numero: ")
    leia (i)
    soma = soma + i

    escreva ("resultado da soma: ", soma,"\n")
   }
   
  }
}
 