programa {
  funcao inicio() {
    inteiro vetor[6] ={12,25,7,30,18,5}
    inteiro numero
    escreva("DIGITE O NUMERO A SER ENCONTRADO: ")
    leia(numero)
    para (inteiro i = 0; i<6;i++)
    {
      se (vetor[i]==numero){
        escreva ("NUMERO NA POSIÇÃO: ", i,"\n")
      }
      
    }


    
  }
}
