programa
{
    funcao inicio()
    {
        real n1, n2, media
        escreva("Digite o primeiro numero: ") //inserir texto para entrada de dados//
        leia(n1)
        escreva("Digite o segundo numero: ") //inserir texto para entrada de dados//
        leia(n2)
        //media = (n1 + n2) / 3//
        media = (n1 + n2) / 2

        escreva("Média: ", media)
    }
}