programa
{
    funcao inicio()
    {
        inteiro senha
        escreva("Digite a senha: ") //texto para entrada de dados//
        leia(senha)
        //se (senha != 1234)// 
        se (senha == 1234) 
        {
            escreva("Acesso liberado")
        }
        senao
        {
            escreva("Senha incorreta")
        }
    }
}