programa {
  funcao inicio() {
    inteiro matriz [2][3] = {
    {10,20,30},
    {40,50,60}
    
    }
    escreva("O ELEMENTO DA LINHA ZERO, COLUNA 1 É: ",matriz[0][1], "\n")
    escreva("O ELEMENTO DA LINHA ZERO, COLUNA 0 É: ",matriz[0][0], "\n")
    escreva("O ELEMENTO DA LINHA ZERO, COLUNA 3 É: ",matriz[0][2], "\n")
    escreva("O ELEMENTO DA LINHA UM, COLUNA 1 É: ",matriz[1][1], "\n")
    escreva("O ELEMENTO DA LINHA UM, COLUNA 2 É: ",matriz[1][2], "\n")

    
  }
}
