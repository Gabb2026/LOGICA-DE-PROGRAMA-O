programa {
  funcao inicio() {
  inteiro notasTurmas[3][4]
  inteiro notas, turmas
  para (notas=)
  para(turmas=0;turmas<3;turmas++){
    escreva(turmas+1, "ª TURMA: ")
    para (notas = 0; notas<4;notas++){
      escreva (notasTurmas[turmas][notas], " \t")
    }
      escreva("\n")
  }
  
  
  

  }
}
