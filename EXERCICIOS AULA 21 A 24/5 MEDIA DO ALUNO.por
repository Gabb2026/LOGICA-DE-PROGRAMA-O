programa {
  funcao inicio() {
    real nota1, nota2, nota3
    cadeia nomeAluno
    real media
    escreva("Digite o nome do aluno: ")
    leia(nomeAluno)
    escreva("Digite a primeira Nota: ")
    leia (nota1)
    escreva("Digite a segunda nota: ")
    leia(nota2)
    escreva ("Digite a terceira nota ")
    leia (nota3) 
    media = (nota1+nota2+nota3)/3
    escreva ("A media do Aluno é: ", media) }
}
